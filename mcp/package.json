{
  "name": "@pairsystems/goodmem-mcp",
  "version": "0.1.1",
  "description": "GoodMem MCP server \u2014 exposes GoodMem API as MCP tools",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "goodmem-mcp": "dist/index.js"
  },
  "files": [
    "dist/index.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && esbuild dist/index.js --bundle --platform=node --format=esm --outfile=dist/index.js --allow-overwrite",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "tsx": "^4.19.4",
    "esbuild": "^0.27.0",
    "@types/node": "^22.15.21"
  }
}
